# Example environment file
# Copy this to .env and update with your actual values

# Secret key for auth tokens
SECRET_KEY=your-secret-key-here

SALT=your-salt-here

# PostgreSQL environment variables (for container initialization)
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=your-database-name

# Database connection environment variables (for application)
DB_URL=postgresql://user:password@host:port/database

# IP Info API Key for fetching IP details primarily for geolocation.
IPINFO_ENDPOINT=https://ipinfo.io
IPINFO_API_KEY=your-ipinfo-api-key

# CORS Configuration - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://localhost:3000

# Redis Configuration
# For local development (Docker container)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_SSL=false
REDIS_SSL_CERT_REQS=required
REDIS_CONNECTION_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5

# For AWS ElastiCache Redis (Production)
# REDIS_HOST=your-redis-cluster.xxxxx.cache.amazonaws.com
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=your-auth-token-if-enabled
# REDIS_USERNAME=default
# REDIS_SSL=true
# REDIS_SSL_CERT_REQS=required
# REDIS_CONNECTION_TIMEOUT=10
# REDIS_SOCKET_TIMEOUT=10

# Additional Redis Configuration Options (Optional)
# REDIS_MAX_CONNECTIONS=50
# REDIS_RETRY_ON_TIMEOUT=true
# REDIS_HEALTH_CHECK_INTERVAL=30
